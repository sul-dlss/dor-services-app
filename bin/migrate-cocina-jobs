#!/usr/bin/env ruby
# frozen_string_literal: true

# Migrates cocina objects.
# Migration is performed by a Migrator class that is provided as an argument.
# The Migrator class should be a subclass of or otherwise implement the interface
# of Migrators::Base.
# The migration is performed by the MigrationJob, which operates on a batch of druids defined by a batch descriptor.
# The MigrationJob uses the migrator class to migrate each individual RepositoryObject from that batch of druids.
# The results are stored in BackgroundJobResult records, and the final output is written to migrate-cocina.csv after
# all jobs are complete.

require_relative '../config/environment'
require 'optparse'

BATCH_SIZE = 25_000
LAST_MIGRATION_FILENAME = 'last-migration.json'

options = { mode: Migrators::MigrationRunner::DEFAULT_MODE, sample: nil, batch: BATCH_SIZE }

parser = OptionParser.new do |option_parser|
  mode_list_str = Migrators::MigrationRunner::MODES.join(', ')
  option_parser.banner = 'Usage: bin/migrate-cocina-jobs MIGRATION_CLASS [options]'
  option_parser.on('--mode [MODE]', Migrators::MigrationRunner::MODES,
                   "Migration mode (#{mode_list_str}). Default is #{options[:mode]}")
  option_parser.on('-sSAMPLE', '--sample SAMPLE', Integer, 'Sample size per type, otherwise all objects.')
  option_parser.on('-bBATCH', '--batch BATCH', Integer,
                   "Batch size for processing. Default is #{BATCH_SIZE}.")
  option_parser.on('-h', '--help', 'Displays help.') do
    additional_hint = 'See README, comments in this script, Migrators::MigrationRunner, Migrators::Base, and ' \
                      'Migrators::Exemplar for more details about migrator implementation and migrator modes.'
    puts "#{option_parser}\n\n**#{additional_hint}**"
    exit
  end
end

if ARGV.empty?
  puts 'You must provide a migration class'
  puts parser
  exit
end

parser.parse!(into: options)
migrator_class = ARGV.shift.constantize

# @return [Array<Integer>] ids of BackgroundJobResult records for the enqueued jobs
def start_migrate(migrator_class:, sample:, processes:, mode:, batch_size:)
  # Pre-compute keyset pagination boundaries (a single indexed scan)
  # so workers can each fetch their slice with an efficient WHERE id > ? LIMIT n query
  batch_descriptors = Migrators::BatchSupport.batch_descriptors(migrator_class:, sample:, batch_size:)
  batch_descriptors.map do |batch_descriptor|
    job_result = BackgroundJobResult.create!(status: :pending)
    MigrationJob.perform_later(migrator_class:, batch_descriptor:, mode:, background_job_result: job_result)
    job_result.id
  end
end

def wait_for_jobs(job_result_ids)
  start = Time.zone.now
  until (status_counts = status_counts_for(job_result_ids))['complete'] == job_result_ids.size
    elapsed_seconds = (Time.zone.now - start).to_i
    elapsed = ActiveSupport::Duration.build(elapsed_seconds).inspect
    puts "Job status counts: #{status_counts.inspect} - #{elapsed} elapsed"
    sleep(30)
  end
end

def status_counts_for(job_result_ids)
  BackgroundJobResult.where(id: job_result_ids).group(:status).count
end

def consolidate_outputs(job_result_ids)
  CSV.open('migrate-cocina.csv', 'w') do |writer|
    job_result_ids.each do |job_result_id|
      job_result = BackgroundJobResult.find(job_result_id)
      job_result.output.each do |result|
        writer << result
      end
    end
  end
end

job_result_ids = if File.exist?(LAST_MIGRATION_FILENAME)
                   puts "#{LAST_MIGRATION_FILENAME} found, so resuming"
                   JSON.parse(File.read(LAST_MIGRATION_FILENAME))

                 else
                   start_migrate(migrator_class:, sample: options[:sample], processes: options[:processes],
                                 mode: options[:mode], batch_size: options[:batch]).tap do |job_result_ids|
                     puts "Enqueued #{job_result_ids.size} jobs with BackgroundJobResult ids: #{job_result_ids.inspect}"
                     File.write(LAST_MIGRATION_FILENAME, job_result_ids.to_json)
                   end
                 end

wait_for_jobs(job_result_ids)

consolidate_outputs(job_result_ids)

puts 'Output written to migrate-cocina.csv'
File.delete(LAST_MIGRATION_FILENAME)

exit 0
