#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative '../../config/environment'
require_relative '../../lib/unique_report'

def identifier_types(ng_xml)
  ng_xml.root.xpath('//mods:identifier/@type', mods: MODS_NS).map(&:content)
end

UniqueReport.new(name: 'desc-identifier_types', dsid: 'descMetadata', report_func: method(:identifier_types)).run
