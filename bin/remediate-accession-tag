# This one was done manually:
# druid: zz047kc0832

require_relative '../config/environment'
MODS = Dor::DescMetadataDS::MODS_NS
NS = { mods: MODS }

def replace_offending_node(item, accessioned)
  ng_xml = item.descMetadata.ng_xml

  bad_query = ng_xml.xpath('//mods:relatedItem[@type="1998-177"][@displayLabel="Accession"]', NS)
  return unless bad_query.present?

  VersionService.open(item, { opening_user_name: 'jcoyne85', significance: 'admin', description: ' remediate incorrect mods' }, event_factory: EventFactory) if accessioned
  bad_query.each do |node|
    node.add_next_sibling '<relatedItem type="series" displayLabel="Accession">
     <titleInfo>
       <title>1998-177</title>
     </titleInfo>
    </relatedItem>'
    node.remove
  end

  item.descMetadata.ng_xml_will_change!
  item.save!
  VersionService.close(item, { user_name: 'jcoyne85', significance: :admin, description: ' remediate incorrect mods' }, event_factory: EventFactory) if accessioned

end

druids.each_with_index do |druid, n|
  puts "#{n} - #{druid}"
  item = Dor.find(druid)
  accessioned = WorkflowClientFactory.build.lifecycle(druid: druid, milestone_name: 'accessioned')
  replace_offending_node(item, accessioned)
end
